<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pup.taguig.app.repositoryM.StudentMapper">

	<resultMap id="studentResultMap" type="com.pup.taguig.app.model.StudentM">
		<id property="id" column="id"/>
        <result property="firstName" column="first_name"/>
        <result property="lastName" column="last_name"/>
        <result property="midtermGrade" column="midterm_grade"/>
        <result property="finalGrade" column="final_grade"/>
        
        <association property="department" resultMap="departmentResultMap"/>
	</resultMap>
	
	<resultMap id="studentResultMap1" type="com.pup.taguig.app.model.StudentM">
		<id property="id" column="id"/>
        <result property="firstName" column="first_name"/>
        <result property="lastName" column="last_name"/>
        <result property="midtermGrade" column="midterm_grade"/>
        <result property="finalGrade" column="final_grade"/>
	</resultMap>
	
	<resultMap id="departmentResultMap" type="com.pup.taguig.app.model.Department">
		<id property="id" column="id"/>
		<result property="name" column="name"/>
		<result property="displayName" column="display_name"/>
	</resultMap>
	
	<!--Student-->
	<select id="retrieveAllStudents" resultMap="studentResultMap">
		SELECT * FROM student;
	</select>
	
	<select id="findUserById" resultMap="studentResultMap">
		SELECT 
			s.id,
			s.first_name,
			s.last_name,
			s.midterm_grade,
			s.final_grade,
			d.id,
			d.name,
			d.display_name
		FROM 
			student s
		LEFT JOIN department d 
			ON s.department_id = d.id
		WHERE 
			s.id = #{id}
	</select>
	
	<insert id="insertStudent" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO student 
			(first_name, last_name, midterm_grade, final_grade) 
        VALUES 
        	(#{firstName}, 
        	#{lastName}, 
        	#{midtermGrade}, 
        	#{finalGrade})
	</insert>
	
	<delete id="deleteStudentById" parameterType="long">
		DELETE 
			FROM student 
		WHERE 
			id = #{id}
	</delete>
</mapper>
